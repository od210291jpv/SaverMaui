<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SaverMaui.ViewModels"
             xmlns:local="clr-namespace:SaverMaui.ViewModels"
             xmlns:vd="clr-namespace:SaverMaui.Custom_Elements"
             x:DataType="local:TopRatedFeedViewModel"
             xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
             x:Class="SaverMaui.Views.TopRatedFeedPage">
    
    <ContentPage.BindingContext>
        <vm:TopRatedFeedViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Content>
        <FlexLayout>
            <CarouselView ItemsSource="{Binding ContentCollection}" CurrentItem="{Binding CurrentContent}">
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="vd:ImageRepresentationElement">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <ffimageloading:CachedImage Grid.Column="0" LoadingPlaceholder="https://png.pngtree.com/png-vector/20190817/ourmid/pngtree-image-icon---vector-loading-download-and-upload-png-image_1694005.jpg"  ErrorPlaceholder="https://png.pngtree.com/png-vector/20190817/ourmid/pngtree-image-icon---vector-loading-download-and-upload-png-image_1694005.jpg" Grid.Row="0" Source="{Binding Path=Source}" Aspect="AspectFit">
                            </ffimageloading:CachedImage>
                            <Button Grid.Row="0" 
                                Grid.Column="0"
                                Text="D"
                                FontAttributes="Bold"
                                TextColor="White"
                                BackgroundColor="DeepPink"
                                CornerRadius="50"
                                VerticalOptions="End"
                                HorizontalOptions="Start"
                                Margin="30"
                                HeightRequest="60"
                                WidthRequest="60"
                                Padding="0"
                                Opacity="0.6"
                                x:Name="DeleteButton"
                                Clicked="OnDeleteClicked"/>
                        </Grid>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
        </FlexLayout>
    </ContentPage.Content>

</ContentPage>