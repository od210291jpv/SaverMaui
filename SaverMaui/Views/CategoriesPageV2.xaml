<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SaverMaui.ViewModels"
             x:Class="SaverMaui.Views.CategoriesPageV2"
             Title="Categories"
             BackgroundColor="Black">

    <ContentPage.BindingContext>
        <vm:CategoriesViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Content>
        <Grid RowDefinitions="Auto, *" Padding="16, 16, 16, 0">

            <Border Grid.Row="0"
                    BackgroundColor="#FF5722" 
                    StrokeThickness="0" 
                    Margin="0, 0, 0, 20"
                    Padding="24, 16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#FF5722" Offset="0,6" Radius="12" Opacity="0.3" />
                </Border.Shadow>

                <Label Text="Categories" 
                       TextColor="White" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Start" 
                       VerticalOptions="Center"/>
            </Border>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Categories}" 
                            SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" 
                            SelectionMode="Single">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="16" HorizontalItemSpacing="16"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#FF5722" 
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.08" />
                            </Border.Shadow>

                            <SwipeView>
                                <SwipeView.LeftItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Open" BackgroundColor="#6750A4" Clicked="OnCategoryOpen"/>
                                    </SwipeItems>
                                </SwipeView.LeftItems>

                                <Grid HeightRequest="120" Padding="16">
                                    <Label Text="{Binding Path=Name}" 
                                           TextColor="White" 
                                           FontSize="18" 
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Grid>
                            </SwipeView>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </Grid>
    </ContentPage.Content>
</ContentPage>