<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SaverMaui.ViewModels"
             x:Class="SaverMaui.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:SettingsViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Content>
        <ScrollView Orientation="Vertical" 
                     HorizontalOptions="FillAndExpand" 
                     VerticalOptions="Start">

            <VerticalStackLayout Spacing="20" Padding="20" BackgroundColor="#121212">
                <!-- 3. Global Actions Card -->
                <Frame CornerRadius="15" 
                       BackgroundColor="#1E1E1E" 
                       HasShadow="True" 
                       Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="⚙️ Global Actions" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#FFFFFF"/>

                        <!-- Sync/Post Buttons -->
                        <Button Text="🔄 Sync Content with Backend" 
                                Command="{Binding SyncContextCommand}"
                                BackgroundColor="#2196F3" 
                                TextColor="White" 
                                FontSize="16" 
                                CornerRadius="10" 
                                HeightRequest="50"/>

                        <Button Text="📤 Post All Data to Backend" 
                                Command="{Binding PostNewContentCommand}"
                                BackgroundColor="#FF9800" 
                                TextColor="White" 
                                FontSize="16" 
                                CornerRadius="10" 
                                HeightRequest="50"/>

                        <!-- Data Management Buttons -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Button Grid.Column="0" Text="🗑️ Erase Empty Categories" 
                                    Command="{Binding EraseEmptyCategoriesCommand}"
                                    BackgroundColor="#F44336" 
                                    TextColor="White" 
                                    CornerRadius="10" 
                                    HeightRequest="45"/>
                            <Button Grid.Column="1" Text="🧹 Wipe All Data" 
                                    Command="{Binding WipeAllDataCommand}"
                                    BackgroundColor="#D32F2F" 
                                    TextColor="White" 
                                    CornerRadius="10" 
                                    HeightRequest="45"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- 4. Search & Toggles Card -->
                <Frame CornerRadius="15" 
                       BackgroundColor="#1E1E1E" 
                       HasShadow="True" 
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="🔍 Search and Preferences" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#FFFFFF"/>

                        <!-- Search Input -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Entry Grid.Column="0" 
                                   Placeholder="Keyword" 
                                   Text="{Binding SearchRequest, Mode=TwoWay}" 
                                   TextColor="#FFFFFF" 
                                   BackgroundColor="#252525" 
                                   HeightRequest="45"/>
                            <Button Grid.Column="1" 
                                    Text="Search" 
                                    Command="{Binding SearchContent}"
                                    BackgroundColor="#FF5722" 
                                    TextColor="White" 
                                    CornerRadius="10" 
                                    HeightRequest="45"/>
                        </Grid>

                        <!-- Search Results Button -->
                        <Button Text="🧹 Clean Search Results" 
                                Command="{Binding CleanSearchResults}"
                                BackgroundColor="#424242" 
                                TextColor="White" 
                                FontSize="16" 
                                CornerRadius="10" 
                                HeightRequest="45"/>

                        <!-- Toggles (Switches) -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                            <Label Grid.Column="0" Text="Log Feeds Content" VerticalOptions="Center" TextColor="#AAAAAA"/>
                            <Switch Grid.Column="1" OnColor="#FF5722" IsToggled="{Binding LogFeedsEnabled, Mode=TwoWay}" />
                        </Grid>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                            <Label Grid.Column="0" Text="Refresh Search Results" VerticalOptions="Center" TextColor="#AAAAAA"/>
                            <Switch Grid.Row="22" Grid.Column="1" OnColor="#FF5722" IsToggled="{Binding RefreshSearchResults, Mode=TwoWay}" Toggled="Handle_Toggled"></Switch>

                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>