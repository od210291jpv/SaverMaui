<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SaverMaui.ViewModels"
             x:Class="SaverMaui.Views.ProfilePage"
             Title="Profile"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:ProfileViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Content>
        <RefreshView IsRefreshing="{Binding IsRefreshing}" BackgroundColor="#121212">
            <ScrollView Orientation="Vertical" 
                         HorizontalOptions="Center" 
                         VerticalOptions="FillAndExpand" 
                         Padding="20" 
                         BackgroundColor="#121212">

                <VerticalStackLayout Spacing="20" VerticalOptions="Start">

                    <!-- Online Status Card (Material Card) -->
                    <Frame CornerRadius="15" 
                           BackgroundColor="#1E1E1E" 
                           HasShadow="True" 
                           Padding="15"
                           HorizontalOptions="FillAndExpand">
                        <Grid ColumnDefinitions="Auto, *">
                            <!-- Online Button -->
                            <Button Grid.Column="0" 
                                    x:Name="OnlineButton"
                                    Text="" 
                                    CornerRadius="90" 
                                    BackgroundColor="{Binding OnlineButtonBackgroundColor}" 
                                    TextColor="White"
                                    BorderColor="White"
                                    VerticalOptions="Center"
                                    HeightRequest="30"
                                    WidthRequest="30"
                                    Clicked="OnOnlineButtonClicked"/>

                            <!-- Profile Greeting/Status -->
                            <Label Grid.Column="1" 
                                   Text="Not Registered yet? Create personal profile to get access to all features!" 
                                   TextColor="#AAAAAA" 
                                   FontSize="16" 
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </Grid>
                    </Frame>

                    <!-- User Info Card (Material Card) -->
                    <Frame CornerRadius="15" 
                           BackgroundColor="#1E1E1E" 
                           HasShadow="True" 
                           Padding="20"
                           HorizontalOptions="FillAndExpand">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="User Profile" 
                                   FontSize="24" 
                                   FontAttributes="Bold" 
                                   HorizontalTextAlignment="Center"
                                   TextColor="#FFFFFF"/>

                            <!-- Username Display -->
                            <Label Text="{Binding UserName, Mode=TwoWay}" 
                                   TextColor="#FF5722" 
                                   FontAttributes="Bold" 
                                   FontSize="28" 
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Search Progress Card (Material Card) -->
                    <Frame CornerRadius="15" 
                           BackgroundColor="#1E1E1E" 
                           HasShadow="True" 
                           Padding="20"
                           HorizontalOptions="FillAndExpand">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Search Progress" 
                                   FontSize="20" 
                                   FontAttributes="Bold" 
                                   TextColor="#FFFFFF"/>

                            <!-- Progress Bar -->
                            <ProgressBar x:Name="SearchProgress" 
                                         ProgressColor="#FF5722" 
                                         HeightRequest="10" />

                            <!-- Status Details -->
                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0" Text="Total Content: " TextColor="#AAAAAA" FontSize="16"/>
                                <Label Grid.Column="1" x:Name="TotalContentAmount" Text="{Binding TotalContentAmount}" TextColor="#FFFFFF" FontSize="16" VerticalOptions="Center"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0" Text="Funds: " TextColor="#AAAAAA" FontSize="16"/>
                                <Label Grid.Column="1" x:Name="Funds" Text="{Binding Funds}" TextColor="#FFFFFF" FontSize="16" VerticalOptions="Center"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0" Text="Results found: " TextColor="#AAAAAA" FontSize="16"/>
                                <Label Grid.Column="1" x:Name="ResultsAmt" Text="{Binding ResultsAmnt}" TextColor="#FFFFFF" FontSize="16" VerticalOptions="Center"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0" Text="Search status: " TextColor="#AAAAAA" FontSize="16"/>
                                <Label Grid.Column="1" x:Name="SearchStatuslabel" Text="{Binding SearchStatus}" TextColor="#FF5722" FontSize="16" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </ContentPage.Content>
</ContentPage>